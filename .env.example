# Runtime environment
CI_COMMIT_BRANCH=develop
IMAGE_TAG=etl-pms-customer:local

# GCP
SECRET_PROJECT_ID=your-gcp-project-id        # [SCRUBBED] replace with your GCP project ID
SECRET_SERVICE_ACCOUNT=your-secret-sa-key    # [SCRUBBED] replace with your Secret Manager key name for service account JSON

# Prefect
PREFECT_API_URL=http://<PREFECT_SERVER_IP>:4200/api  # [SCRUBBED] replace with your Prefect server IP/hostname
PREFECT_WORK_POOL=kubernetes-pool
PREFECT_WORK_QUEUE=default

# Job date (default = yesterday ICT)
JOB_YEAR=None
JOB_MONTH=None
JOB_DAY=None
JOB_FULL_DATA=0

# mobileregister history depth
JOB_NUMOFYER=10
JOB_HISOFYER=2026
